# Local working memory for pyctrl development (loaded by the pyctrl skill, not versioned)
.claude/memory/

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
.venv-engine/
venv/
*.egg-info/

# Captured params sidecars are regenerable; the .bin references are committed.
tests/reference/*.params.json
tests/reference_engine/*.params.json

# Throwaway capture artifacts from tools/run_lacscan_once.py (regenerable images).
tools/last_lacscan.*
tools/last_lacscan_gray.*

# Pretty-printed (derived) copies of committed JSON references.
tests/reference/*.pretty.json

# Throwaway scratch: diagnostic run/submit/analysis scripts + figures + JSON dumps.
tmp/
tools/seq_dump_timing.json
